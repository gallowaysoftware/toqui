# Toqui self-host config. Copy this to `.env` and fill in.
# `docker compose up` reads `.env` automatically.

# ── Required ────────────────────────────────────────────────────────────────
# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=

# ── AI provider — at least one is required ─────────────────────────────────
# Pick whichever you have. The backend tries them in this order:
# Anthropic → OpenAI → Vertex AI Gemini.

# Anthropic Claude. https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI or any OpenAI-compatible endpoint (OpenRouter, Ollama, vLLM,
# LM Studio, Together, etc.). For non-OpenAI endpoints, set OPENAI_BASE_URL.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1   # local Ollama

# Vertex AI Gemini. Requires a GCP project with Vertex enabled +
# Application Default Credentials mounted into the container.
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1

# ── Optional: Google OAuth ──────────────────────────────────────────────────
# Leave unset to disable Google sign-in (the frontend will only show
# email + password). To enable, create an OAuth client at
# https://console.cloud.google.com/apis/credentials and set:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Optional: URLs ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:8090

# ── Optional: Postgres credentials override ─────────────────────────────────
# POSTGRES_PASSWORD=toqui
