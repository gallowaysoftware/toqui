# Required for Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI provider — Claude is primary, Gemini (Vertex AI) is automatic fallback
ANTHROPIC_API_KEY=

# Vertex AI (Gemini) — uses Application Default Credentials, no API key needed
# Set project ID to route Vertex AI billing to the correct GCP project
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1

# Cost control (daily token budget across all AI calls, 0 = unlimited)
DAILY_AI_TOKEN_BUDGET=0

# Optional: Google APIs for tools
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=
GOOGLE_PLACES_API_KEY=
