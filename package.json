{
  "name": "toqui",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "build:ios": "expo export --platform ios",
    "build:android": "expo export --platform android",
    "build:ios:dev": "eas build --platform ios --profile development",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:prod": "eas build --platform ios --profile production",
    "build:android:dev": "eas build --platform android --profile development",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "generate": "buf generate --template buf.gen.yaml ./backend/proto"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@maplibre/maplibre-react-native": "^11.2.1",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@tanstack/react-query": "^5.100.13",
    "expo": "~55.0.26",
    "expo-auth-session": "^55.0.15",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "~55.0.15",
    "expo-crypto": "^55.0.14",
    "expo-document-picker": "^55.0.13",
    "expo-file-system": "^56.0.7",
    "expo-glass-effect": "55.0.8",
    "expo-image": "55.0.6",
    "expo-linking": "~55.0.14",
    "expo-location": "^55.1.8",
    "expo-modules-core": "55.0.18",
    "expo-print": "^55.0.13",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "^55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "^55.0.14",
    "i18next": "^26.2.0",
    "lucide-react-native": "^1.16.0",
    "punycode": "^2.3.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "^17.0.8",
    "react-native": "0.83.9",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-markdown-display": "^7.0.2",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "~15.15.5",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "~19.2.15",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "protobufjs@>=7.0.0 <7.5.5": "^7.5.6",
      "dompurify@<3.4.0": "^3.4.0",
      "@xmldom/xmldom@<0.8.13": "^0.8.13",
      "markdown-it@<12.3.2": "^12.3.2"
    },
    "patchedDependencies": {
      "expo-glass-effect@55.0.8": "patches/expo-glass-effect@55.0.8.patch",
      "expo-image@55.0.6": "patches/expo-image@55.0.6.patch",
      "expo-modules-core@55.0.18": "patches/expo-modules-core@55.0.18.patch",
      "expo-router@55.0.8": "patches/expo-router@55.0.8.patch",
      "react-native-screens@4.23.0": "patches/react-native-screens@4.23.0.patch"
    }
  },
  "private": true
}
