{
  "cli": {
    "version": ">= 14.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:8090",
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "279747392992-ciuopbpr3b374437qdgov508kpnm8ja3.apps.googleusercontent.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-staging.toqui.travel",
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "279747392992-ciuopbpr3b374437qdgov508kpnm8ja3.apps.googleusercontent.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.toqui.travel",
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "194088718926-1rdk2kkmgl72t9kae73e9oq84aobtv2h.apps.googleusercontent.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "APPLE_ID_PLACEHOLDER",
        "ascAppId": "ASC_APP_ID_PLACEHOLDER",
        "appleTeamId": "APPLE_TEAM_ID_PLACEHOLDER"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal"
      }
    }
  }
}
