# Production environment — secrets fetched from GCP Secret Manager
# Loaded when TARGET_ENV=prod
# Values starting with gcsm:// are resolved via Secret Manager at startup

PORT=8090
DATABASE_URL=gcsm://prod-database-url
FIRESTORE_PROJECT_ID=toqui-prod

GOOGLE_CLIENT_ID=gcsm://prod-google-client-id
GOOGLE_CLIENT_SECRET=gcsm://prod-google-client-secret
GOOGLE_REDIRECT_URI=https://api.toqui.com/auth/google/callback

JWT_SECRET=gcsm://prod-jwt-secret

ANTHROPIC_API_KEY=gcsm://anthropic-api-key
OPENAI_API_KEY=

FRONTEND_URL=https://toqui.com

GOOGLE_CUSTOM_SEARCH_API_KEY=gcsm://google-custom-search-api-key
GOOGLE_CUSTOM_SEARCH_CX=gcsm://google-custom-search-cx
GOOGLE_PLACES_API_KEY=gcsm://google-places-api-key
