# Production environment — secrets fetched from GCP Secret Manager
# Loaded when TARGET_ENV=prod
# Values starting with gcsm:// are resolved via Secret Manager at startup

PORT=8090
DATABASE_URL=gcsm://prod-database-url
FIRESTORE_PROJECT_ID=toqui-prod

GOOGLE_CLIENT_ID=gcsm://prod-google-client-id
GOOGLE_CLIENT_SECRET=gcsm://prod-google-client-secret
GOOGLE_REDIRECT_URI=https://api.toqui.travel/auth/google/callback

JWT_SECRET=gcsm://prod-jwt-secret

ANTHROPIC_API_KEY=gcsm://anthropic-api-key

# Gemini Developer API (primary) — supports Gemini 3 models
GEMINI_API_KEY=gcsm://gemini-api-key

# Vertex AI (fallback) — uses Cloud Run service account ADC, global endpoint
VERTEX_AI_PROJECT_ID=toqui-prod
VERTEX_AI_LOCATION=us-central1
DAILY_AI_TOKEN_BUDGET=5000000

# Hard daily AI cost cap (in cents). Backed by daily_usage rows in Postgres,
# so it survives Cloud Run revision restarts and is shared across instances —
# unlike DAILY_AI_TOKEN_BUDGET which resets per-process. Worst-case scripted
# attacker with 100 burner accounts is bounded here, not in upstream rate
# limits. Set to $50/day for solo-dev launch; raise once usage telemetry is real.
AI_DAILY_BUDGET_CENTS=5000

FRONTEND_URL=https://toqui.travel

GOOGLE_CUSTOM_SEARCH_API_KEY=gcsm://google-custom-search-api-key
GOOGLE_CUSTOM_SEARCH_CX=gcsm://google-custom-search-cx
GOOGLE_PLACES_API_KEY=gcsm://google-places-api-key
