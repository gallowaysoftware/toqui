# Staging environment — secrets fetched from GCP Secret Manager
# Loaded when TARGET_ENV=staging
# Values starting with gcsm:// are resolved via Secret Manager at startup

PORT=8090
DATABASE_URL=gcsm://staging-database-url
FIRESTORE_PROJECT_ID=toqui-staging

GOOGLE_CLIENT_ID=gcsm://staging-google-client-id
GOOGLE_CLIENT_SECRET=gcsm://staging-google-client-secret
GOOGLE_REDIRECT_URI=https://staging-api.toqui.travel/auth/google/callback

JWT_SECRET=gcsm://staging-jwt-secret

ANTHROPIC_API_KEY=gcsm://staging-anthropic-api-key

# Vertex AI Gemini fallback — uses GCE service account ADC
VERTEX_AI_PROJECT_ID=toqui-staging
VERTEX_AI_LOCATION=us-central1
DAILY_AI_TOKEN_BUDGET=2000000

FRONTEND_URL=https://staging-app.toqui.travel

GOOGLE_CUSTOM_SEARCH_API_KEY=gcsm://staging-google-custom-search-api-key
GOOGLE_CUSTOM_SEARCH_CX=gcsm://staging-google-custom-search-cx
GOOGLE_PLACES_API_KEY=gcsm://staging-google-places-api-key

RESEND_API_KEY=gcsm://staging-resend-api-key

# Staging overrides — all users get permanent pro
STAGING_PRO_ALL=true

# Affiliate partners
VIATOR_PARTNER_ID=gcsm://staging-viator-partner-id
