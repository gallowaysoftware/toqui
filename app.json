{
  "expo": {
    "name": "Toqui",
    "slug": "toqui",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "toqui",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#e8654a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "travel.toqui.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Toqui uses your location to recommend nearby restaurants, attractions, and experiences while you travel.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "travel.toqui.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e8654a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@maplibre/maplibre-react-native",
      "@react-native-community/datetimepicker",
      "expo-document-picker",
      "./plugins/xcode16-compat"
    ]
  }
}
