{
  "expo": {
    "name": "Toqui",
    "slug": "toqui",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "toqui",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#e8654a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "travel.toqui.app"
    },
    "android": {
      "package": "travel.toqui.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e8654a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
